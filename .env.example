# ===========================================
# Smart WaterVerse — Environment Variables
# ===========================================
# Copy to .env and fill in values

# --- Database (PostgreSQL + TimescaleDB) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartwater
POSTGRES_USER=smartwater
POSTGRES_PASSWORD=changeme_dev_only

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MQTT (Mosquitto) ---
MQTT_BROKER_URL=mqtt://localhost:1883

# --- JWT Auth ---
JWT_SECRET=changeme_replace_with_64char_random_string
JWT_EXPIRES_IN=7d

# --- Object Storage ---
# Dev: MinIO | Prod: AWS S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smartwater-uploads
S3_REGION=us-east-1

# --- Notifications ---
# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# AWS SES (free tier: 62K emails/month)
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@smartwaterverse.com

# Firebase Cloud Messaging (for React Native push)
FCM_SERVER_KEY=

# --- IoT Simulator ---
SIMULATOR_SITE_COUNT=20
SIMULATOR_INTERVAL_MS=5000

# --- API Server ---
API_PORT=3001
API_HOST=0.0.0.0

# --- Frontend URLs ---
OPS_DASHBOARD_URL=http://localhost:5173
RWA_PORTAL_URL=http://localhost:5174
